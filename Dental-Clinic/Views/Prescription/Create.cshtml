@model Prescription
@{
    var appt = ViewBag.Appointment;
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">🦷 Prescription</h5>
    </div>

    <div class="card-body">
        <form asp-action="Create" method="post">

            <input type="hidden" asp-for="AppointmentId" />

            <div class="mb-3">
                <label class="form-label">Doctor Name</label>
                <input asp-for="DoctorName" class="form-control" />
            </div>

            <hr />

            <h6>Medicines</h6>

            <div id="medicineList">

                <!-- 1 -->
                <div class="row mb-2 align-items-center medicine-row">
                    <div class="col-md-3">
                        <input name="Items[0].MedicineName" class="form-control" value="Augmentin" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[0].Dosage" class="form-control" value="625 mg" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[0].Duration" class="form-control" value="3 Days" />
                    </div>
                    <div class="col-md-4">
                        <input name="Items[0].Instructions" class="form-control" placeholder="After meal" />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                    </div>
                </div>

                <!-- 2 -->
                <div class="row mb-2 align-items-center medicine-row">
                    <div class="col-md-3">
                        <input name="Items[1].MedicineName" class="form-control" value="Synflex" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[1].Dosage" class="form-control" value="550 mg" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[1].Duration" class="form-control" value="3 Days" />
                    </div>
                    <div class="col-md-4">
                        <input name="Items[1].Instructions" class="form-control" placeholder="After meal" />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                    </div>
                </div>

                <!-- 3 -->
                <div class="row mb-2 align-items-center medicine-row">
                    <div class="col-md-3">
                        <input name="Items[2].MedicineName" class="form-control" value="Flagyl" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[2].Dosage" class="form-control" value="200 mg" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[2].Duration" class="form-control" value="3 Days" />
                    </div>
                    <div class="col-md-4">
                        <input name="Items[2].Instructions" class="form-control" placeholder="After meal" />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                    </div>
                </div>

                <!-- 4 -->
                <div class="row mb-2 align-items-center medicine-row">
                    <div class="col-md-3">
                        <input name="Items[3].MedicineName" class="form-control" value="Riam" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[3].Dosage" class="form-control" value="" placeholder="Dosage" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[3].Duration" class="form-control" value="3 Days" />
                    </div>
                    <div class="col-md-4">
                        <input name="Items[3].Instructions" class="form-control" placeholder="After meal" />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                    </div>
                </div>

                <!-- 5 -->
                <div class="row mb-2 align-items-center medicine-row">
                    <div class="col-md-3">
                        <input name="Items[4].MedicineName" class="form-control" value="Danzen DS" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[4].Dosage" class="form-control" value="" placeholder="Dosage" />
                    </div>
                    <div class="col-md-2">
                        <input name="Items[4].Duration" class="form-control" value="3 Days" />
                    </div>
                    <div class="col-md-4">
                        <input name="Items[4].Instructions" class="form-control" placeholder="After meal" />
                    </div>
                    <div class="col-md-1 text-end">
                        <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                    </div>
                </div>

            </div>

            <button type="button" class="btn btn-sm btn-secondary mb-3" onclick="addRow()">
                + Add Medicine
            </button>

            <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea asp-for="Notes" class="form-control"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">
                💾 Save & Print
            </button>


        </form>
    </div>
</div>

@section Scripts {
    <script>
        let index = 5;

        function addRow() {
            document.getElementById('medicineList').insertAdjacentHTML('beforeend', `
            <div class="row mb-2 align-items-center medicine-row">
                <div class="col-md-3">
                    <input name="Items[${index}].MedicineName" class="form-control" />
                </div>
                <div class="col-md-2">
                    <input name="Items[${index}].Dosage" class="form-control" />
                </div>
                <div class="col-md-2">
                    <input name="Items[${index}].Duration" class="form-control" />
                </div>
                <div class="col-md-4">
                    <input name="Items[${index}].Instructions" class="form-control" />
                </div>
                <div class="col-md-1 text-end">
                    <button type="button" class="btn btn-sm btn-danger" onclick="removeRow(this)">✖</button>
                </div>
            </div>`);
            index++;
        }

        function removeRow(button) {
            const row = button.closest('.medicine-row');
            row.remove();
        }

    </script>
}
