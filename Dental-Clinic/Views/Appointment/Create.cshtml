@model Appointment
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Book Appointment | Numan Dental Clinic</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        body {
            background: linear-gradient(135deg, #0d6efd, #00c6ff);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Segoe UI', sans-serif;
            padding: 20px;
        }

        .booking-card {
            background: #fff;
            border-radius: 25px;
            box-shadow: 0 20px 50px rgba(0,0,0,0.2);
            overflow: hidden;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .booking-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 25px 60px rgba(0,0,0,0.25);
            }

        .booking-header {
            background: linear-gradient(135deg, #0d6efd, #004aad);
            color: #fff;
            padding: 30px;
            text-align: center;
        }

        .clinic-brand {
            font-size: 26px;
            font-weight: 700;
        }

        .subtitle {
            opacity: 0.9;
            font-size: 14px;
        }

        .form-control, .form-select, textarea {
            border-radius: 12px;
            padding: 12px 15px;
            box-shadow: 0 3px 10px rgba(0,0,0,0.05);
            transition: all 0.3s ease;
        }

            .form-control:focus, .form-select:focus, textarea:focus {
                box-shadow: 0 5px 15px rgba(13,110,253,0.3);
                border-color: #0d6efd;
            }

        .btn-success {
            border-radius: 50px;
            padding: 12px 30px;
            font-weight: 600;
            transition: all 0.3s ease;
        }

            .btn-success:hover {
                transform: scale(1.05);
            }


        /* Responsive tweaks */
        @@media(max - width:768px) {
            .booking-card

        {
            margin: 15px;
        }

        .booking-header {
            padding: 20px;
        }

        }
    </style>
</head>

<body>

    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-7 col-md-10">

                <div class="booking-card">

                    <div class="booking-header">
                        <div class="clinic-brand">
                            <i class="bi bi-tooth me-2"></i>
                            Numan Dental & Aesthetic Clinic
                        </div>
                        <div class="subtitle">
                            Book your appointment in less than 30 seconds
                        </div>
                    </div>

                    <div class="p-4 p-md-5">

                        <form asp-action="Create" method="post">

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Patient Name *</label>
                                    <input asp-for="PatientName" class="form-control" placeholder="Ahmed Khan" required />
                                    <span asp-validation-for="PatientName" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Phone / WhatsApp *</label>
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="03XXXXXXXXX" required />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="row g-3 mt-2">
                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Date</label>
                                    <input asp-for="AppointmentDate" type="date" class="form-control" min="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Time (2PM – 8PM)</label>
                                    <select asp-for="AppointmentTime" class="form-select" required>
                                        <option value="">Select Time</option>
                                        <option value="14:00:00">2:00 PM</option>
                                        <option value="14:30:00">2:30 PM</option>
                                        <option value="15:00:00">3:00 PM</option>
                                        <option value="15:30:00">3:30 PM</option>
                                        <option value="16:00:00">4:00 PM</option>
                                        <option value="16:30:00">4:30 PM</option>
                                        <option value="17:00:00">5:00 PM</option>
                                        <option value="17:30:00">5:30 PM</option>
                                        <option value="18:00:00">6:00 PM</option>
                                        <option value="18:30:00">6:30 PM</option>
                                        <option value="19:00:00">7:00 PM</option>
                                        <option value="19:30:00">7:30 PM</option>
                                        <option value="20:00:00">8:00 PM</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">Branch *</label>
                                    <select asp-for="Branch" asp-items="@(new SelectList(ViewBag.Branches))" class="form-select" required>
                                        <option value="">Select Branch</option>
                                    </select>
                                    <span asp-validation-for="Branch" class="text-danger"></span>
                                </div>
                            </div>

                            <div class="mt-3">
                                <label class="form-label fw-semibold">Reason (Optional)</label>
                                <textarea asp-for="Message" class="form-control" rows="3" placeholder="Briefly describe your concern..."></textarea>
                            </div>

                            <div class="d-grid mt-4">
                                <button type="submit" class="btn btn-success" id="submitBtn">
                                    <span id="btnText">
                                        <i class="bi bi-calendar-check me-2"></i>
                                        Confirm Appointment
                                    </span>
                                </button>
                            </div>

                        </form>

                    </div>

                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>

        // Submit loader
        document.querySelector("form").addEventListener("submit", function () {
            document.getElementById("btnText").innerHTML =
                '<span class="spinner-border spinner-border-sm me-2"></span> Booking...';
        });

        // Animated Success Popup
        @if (TempData["Success"] != null)
        {
                <text>
                Swal.fire({
                    icon: 'success',
                    title: 'Appointment Confirmed!',
                    text: '@TempData["Success"]',
                    confirmButtonColor: '#0d6efd',
                    confirmButtonText: 'Great!',
                    backdrop: `
                        rgba(0,0,0,0.4)
                        url("https://media.giphy.com/media/26ufdipQqU2lhNA4g/giphy.gif")
                        center top
                        no-repeat
                    `
                });
                </text>
        }
    </script>

</body>
</html>